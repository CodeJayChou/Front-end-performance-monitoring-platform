{
  "name": "fe-monitor-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "前端性能监控平台 — RUM + Error + Performance + Session Replay",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:mvp:integration": "vitest run scripts/mvp.integration.test.ts",
    "test:watch": "vitest",
    "mvp:db:up": "docker compose -f infrastructure/docker/docker-compose.mvp.yml up -d postgres",
    "mvp:db:down": "docker compose -f infrastructure/docker/docker-compose.mvp.yml down",
    "mvp:up": "docker compose -f infrastructure/docker/docker-compose.mvp.yml up -d --build",
    "mvp:down": "docker compose -f infrastructure/docker/docker-compose.mvp.yml down",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "pg": "^8.13.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
